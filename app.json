{
  "expo": {
    "name": "gabarito-app",
    "slug": "gabarito-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/teste.png",
    "scheme": "gabaritoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.higorwinchester.gabaritoapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/teste.png",
        "backgroundImage": "./assets/images/teste.png",
        "monochromeImage": "./assets/images/teste.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.higorwinchester.gabaritoapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/teste.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/teste.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "react-native-document-scanner-plugin",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17853b52-e67c-4ec9-8fab-3b5576336631"
      }
    }
  }
}
